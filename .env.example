# ============================================================
#  VARIABLES DE ENTORNO - Backend microservicios SoftCorp
# ============================================================
#  En LOCAL: copia a .env de cada servicio (o exporta en tu shell).
#  En RENDER: se configuran en cada web service (o via grupo compartido).
# ============================================================

# ===== BASE DE DATOS (compartida por los 3 servicios) =====
SPRING_DATASOURCE_URL=jdbc:postgresql://HOST:5432/NOMBRE_BD
SPRING_DATASOURCE_USERNAME=tu_usuario
SPRING_DATASOURCE_PASSWORD=tu_password

# ===== JWT (la MISMA clave en los 3 servicios) =====
TOKEN_JWT_SECRET=cambia_esto_por_una_clave_larga_y_aleatoria_min_32_chars

# ===== JPA (opcional) =====
JPA_DDL_AUTO=update          # en produccion: validate
JPA_SHOW_SQL=false

# ===== Swagger / Dev helper (opcional) =====
SPRINGDOC_ENABLED=true
DEV_HELPER_ENABLED=false      # endpoint /dev/hash; solo cuando lo necesites

# ============================================================
#  ENRUTADO ENTRE SERVICIOS (URLs publicas)
#  En LOCAL puedes omitirlas (usan localhost por defecto).
#  En RENDER: pon las URLs .onrender.com reales.
# ============================================================
# --- Gateway ---
IDENTIDAD_URI=https://softcorp-identidad.onrender.com
INCIDENCIAS_URI=https://softcorp-incidencias.onrender.com
EQUIPOS_URI=https://softcorp-equipos.onrender.com
CORS_ALLOWED_ORIGINS=https://tu-sitio.netlify.app
# --- Incidencias (necesita solo la de Identidad) ---
# IDENTIDAD_URI=https://softcorp-identidad.onrender.com

# ============================================================
#  EUREKA / CONFIG SERVER (solo desarrollo local, opcional)
# ============================================================
EUREKA_ENABLED=false          # true si levantas Eureka en local
# EUREKA_URL=http://localhost:8761/eureka/
# CONFIG_SERVER_URL=http://localhost:8888
